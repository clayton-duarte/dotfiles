[user]
	email = cpd@duck.com
	name = cpd
	signingkey = ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIJfW9sXv6Shm1s9sMDZtUN51InfP4oclRwZnrIKKeRdb

[push]
	autoSetupRemote = true
	useForceIfIncludes = true

[core]
	editor = code --wait

[pull]
	rebase = true

[merge]
	ff = false

[rebase]
	autoStash = true

# SSH commit signing (op-ssh-sign program set by bootstrap.sh per-platform)
[gpg]
	format = ssh

[commit]
	gpgsign = true

[gpg "ssh"]
	allowedSignersFile = ~/.ssh/allowed_signers
	program = /Applications/1Password.app/Contents/MacOS/op-ssh-sign

[init]
	defaultBranch = main
