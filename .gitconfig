[user]
	email = cpd@duck.com
	name = cpd
	# Public key only — not a secret. bootstrap.sh updates this when generating a new key.
	signingkey = ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIJPZF2EcEcJsaza5b7XRkFqBfNZFXKHHba/GYjuGOskC

[push]
	autoSetupRemote = true
	useForceIfIncludes = true

[core]
	editor = code --wait

[pull]
	rebase = true

[merge]
	ff = false

[rebase]
	autoStash = true

# SSH commit signing (program path is platform-specific, bootstrap.sh updates it per-OS)
[gpg]
	format = ssh

[commit]
	gpgsign = true

[gpg "ssh"]
	allowedSignersFile = ~/.ssh/allowed_signers
	program = /Applications/1Password.app/Contents/MacOS/op-ssh-sign

[init]
	defaultBranch = main
