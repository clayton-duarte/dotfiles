[user]
	email = cpd@duck.com
	name = cpd
	# Public key only — not a secret. bootstrap.sh updates this when generating a new key.
	signingkey = ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAILKOe4oZWR3HMGU1yKEgsb3KtO/B3dYlh0MQyEHqCiD6

[push]
	autoSetupRemote = true
	useForceIfIncludes = true

[core]
	editor = code --wait

[pull]
	rebase = true

[merge]
	ff = false

[rebase]
	autoStash = true

# SSH commit signing — key file based, works on all platforms
[gpg]
	format = ssh

[commit]
	gpgsign = true

[gpg "ssh"]
	allowedSignersFile = ~/.ssh/allowed_signers

[init]
	defaultBranch = main
